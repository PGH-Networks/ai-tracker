# ---------------------------------------------------------------------------
# PGH Collab Platform — environment
# Copy to .env.local for local dev. Never commit real secrets.
# ---------------------------------------------------------------------------

# Postgres (Azure or local). Prisma reads this.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/pgh_collab?schema=public"

# Auth.js core. Generate with: npx auth secret  (or openssl rand -base64 32)
AUTH_SECRET="change-me"
# Public base URL of the app (used for callbacks / magic links)
AUTH_URL="http://localhost:3000"

# --- Staff sign-in: Microsoft Entra ID (Azure AD) ---
# App registration in Entra. Redirect URI: {AUTH_URL}/api/auth/callback/microsoft-entra-id
AUTH_MICROSOFT_ENTRA_ID_ID=""
AUTH_MICROSOFT_ENTRA_ID_SECRET=""
# Tenant issuer, e.g. https://login.microsoftonline.com/<TENANT_ID>/v2.0
AUTH_MICROSOFT_ENTRA_ID_ISSUER=""

# --- Client sign-in: passwordless magic link (Nodemailer/SMTP) ---
# For local dev, run Mailpit (docker run -p 1025:1025 -p 8025:8025 axllent/mailpit)
EMAIL_SERVER="smtp://localhost:1025"
EMAIL_FROM="PGH Collab <no-reply@pghnetworks.com>"

# --- Local dev convenience ---
# Comma-separated emails auto-provisioned as ADMIN on first seed.
ADMIN_EMAILS="gregorypack1@gmail.com"

# --- SECURITY DEFERRAL (build-out only) ---
# When "true", there is NO login gate: every request runs as a default user.
# This skips Entra/SMTP entirely so features can be built first.
# Set to "false" (or remove) to restore real Auth.js sign-in + RBAC.
AUTH_DISABLED="true"
# Optional: impersonate a specific seeded user while AUTH_DISABLED.
# Leave blank to run as the first ADMIN; set to the seeded client to test
# the client-scoped views, e.g. DEV_USER_EMAIL="client@acme.example"
DEV_USER_EMAIL=""
