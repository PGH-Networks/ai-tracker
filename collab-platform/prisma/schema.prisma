// PGH Networks — Client AI Collaboration Platform
// Single PGH workspace. Client accounts are the data-isolation boundary.
// This schema is intentionally complete through Phase 5 so later features
// (whiteboard, Fireflies API sync, proposals) require no migration.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================================================
// RBAC + Auth.js (database sessions)
// ===========================================================================

enum Role {
  ADMIN // full CRUD, user management, all financials, settings
  INTERNAL // manage clients/projects/notes/calculator, sees internal cost data
  CLIENT // read-mostly, scoped to own client(s), no cost/margin data
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(CLIENT)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  memberships ClientMembership[] // CLIENT users -> the clients they may see

  // authored content
  createdClients  Client[]        @relation("ClientCreatedBy")
  ownedProjects   Project[]       @relation("ProjectOwner")
  notes           Note[]
  meetingRecords  MeetingRecord[]
  quickLinks      QuickLink[]
  boards          Board[]
  estimates       Estimate[]
  proposals       Proposal[]
  auditLogs       AuditLog[]
}

// Auth.js standard models -------------------------------------------------
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ===========================================================================
// Core engagement entities
// ===========================================================================

enum ClientStatus {
  PROSPECT
  ACTIVE
  ARCHIVED
}

model Client {
  id          String       @id @default(cuid())
  name        String
  status      ClientStatus @default(PROSPECT)
  industry    String?
  website     String?
  // primary point of contact (denormalized for quick display)
  contactName  String?
  contactEmail String?
  notes        String?     @db.Text
  createdById  String?
  createdBy    User?       @relation("ClientCreatedBy", fields: [createdById], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  memberships    ClientMembership[]
  projects       Project[]
  noteEntries    Note[]
  meetingRecords MeetingRecord[]
  quickLinks     QuickLink[]
  roadmapItems   RoadmapItem[]
  tags           Tag[]      @relation("ClientTags")

  @@index([status])
}

// Scopes a CLIENT user to the client(s) they're allowed to see.
// ADMIN/INTERNAL ignore this table (they see everything).
model ClientMembership {
  id        String   @id @default(cuid())
  userId    String
  clientId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([userId, clientId])
  @@index([clientId])
}

// Goals / Projects / Initiatives — self-nesting under a Client.
enum ProjectKind {
  GOAL
  PROJECT
  INITIATIVE
}

enum ProjectStatus {
  PLANNED
  IN_PROGRESS
  BLOCKED
  DONE
  ON_HOLD
}

model Project {
  id          String        @id @default(cuid())
  clientId    String
  parentId    String? // nesting: GOAL -> PROJECT -> INITIATIVE
  kind        ProjectKind   @default(PROJECT)
  name        String
  description String?       @db.Text
  status      ProjectStatus @default(PLANNED)
  ownerId     String?
  startDate   DateTime?
  targetDate  DateTime?
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  parent   Project?  @relation("ProjectTree", fields: [parentId], references: [id])
  children Project[] @relation("ProjectTree")
  owner    User?     @relation("ProjectOwner", fields: [ownerId], references: [id])

  notes          Note[]
  meetingRecords MeetingRecord[]
  quickLinks     QuickLink[]
  boards         Board[]
  roadmapItems   RoadmapItem[]
  estimates      Estimate[]
  proposals      Proposal[]
  tags           Tag[]           @relation("ProjectTags")

  @@index([clientId])
  @@index([parentId])
  @@index([status])
}

// Visibility gate reused across Notes, MeetingRecords, Boards.
enum Visibility {
  INTERNAL // staff only
  CLIENT_VISIBLE // approved for the client to see
}

// ===========================================================================
// Knowledge & meeting capture
// ===========================================================================

model Note {
  id          String     @id @default(cuid())
  clientId    String
  projectId   String?
  title       String
  body        String     @db.Text // rich text (HTML or serialized JSON)
  meetingDate DateTime?
  attendees   String[]   @default([])
  visibility  Visibility @default(INTERNAL)
  authorId    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  client  Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  author  User?    @relation(fields: [authorId], references: [id])
  tags    Tag[]    @relation("NoteTags")

  @@index([clientId])
  @@index([projectId])
  @@index([visibility])
}

// Source of a meeting record. The whole point: manual + api share one schema.
enum RecordSource {
  MANUAL
  API
}

enum RecordProvider {
  FIREFLIES
  OTHER
}

// Fireflies archive (Phase 1 = manual paste, Phase 5 = API upsert on externalId).
// An API sync simply populates the same fields a person fills in by hand.
model MeetingRecord {
  id            String         @id @default(cuid())
  clientId      String
  projectId     String?
  title         String
  meetingDate   DateTime?
  attendees     String[]       @default([])
  summary       String?        @db.Text
  recordingUrl  String?
  transcriptUrl String?
  transcript    String?        @db.Text // optional inline transcript (API may fill this)
  durationSec   Int?
  visibility    Visibility     @default(INTERNAL)

  // --- pluggable ingestion contract ---
  source     RecordSource   @default(MANUAL)
  provider   RecordProvider @default(FIREFLIES)
  externalId String? // provider's id; nullable for manual entries
  syncedAt   DateTime? // last successful API sync; null for manual

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy User?    @relation(fields: [createdById], references: [id])
  tags      Tag[]    @relation("MeetingTags")

  // API sync upserts against (provider, externalId) — dedup vs manual rows.
  @@unique([provider, externalId])
  @@index([clientId])
  @@index([projectId])
  @@index([source])
}

// Fast-link manager — frequently used resources per client/project.
model QuickLink {
  id          String   @id @default(cuid())
  clientId    String?
  projectId   String?
  label       String
  url         String
  sortOrder   Int      @default(0)
  createdById String?
  createdAt   DateTime @default(now())

  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User?    @relation(fields: [createdById], references: [id])

  @@index([clientId])
  @@index([projectId])
}

// Tagging across entities (implicit M2M join tables per relation).
model Tag {
  id        String   @id @default(cuid())
  label     String   @unique
  color     String?
  createdAt DateTime @default(now())

  clients  Client[]        @relation("ClientTags")
  projects Project[]       @relation("ProjectTags")
  notes    Note[]          @relation("NoteTags")
  meetings MeetingRecord[] @relation("MeetingTags")
}

// ===========================================================================
// Whiteboard (Phase 4) — relational metadata + CRDT binary, RBAC-gated.
// Build-vs-buy of the realtime transport is deferred; storage is ready now.
// ===========================================================================

model Board {
  id          String     @id @default(cuid())
  projectId   String
  name        String     @default("Untitled board")
  visibility  Visibility @default(INTERNAL)
  createdById String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User?    @relation(fields: [createdById], references: [id])
  doc       BoardDoc?

  @@index([projectId])
  @@index([visibility])
}

// Persisted CRDT document. `state` holds the Yjs binary update (Y.encodeStateAsUpdate).
// Kept 1:1 with Board and out of the hot Board row so large blobs don't bloat lists.
model BoardDoc {
  boardId   String   @id
  state     Bytes // Yjs document state (or provider snapshot)
  version   Int      @default(0)
  updatedAt DateTime @updatedAt

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
}

// ===========================================================================
// Planning & financials (Phase 3)
// ===========================================================================

enum RoadmapStatus {
  PLANNED
  IN_PROGRESS
  DONE
  AT_RISK
}

model RoadmapItem {
  id          String        @id @default(cuid())
  clientId    String
  projectId   String?
  title       String
  description String?       @db.Text
  status      RoadmapStatus @default(PLANNED)
  startDate   DateTime?
  endDate     DateTime?
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  budgetItems BudgetItem[]

  @@index([clientId])
  @@index([projectId])
}

model BudgetItem {
  id            String   @id @default(cuid())
  roadmapItemId String
  label         String
  amount        Decimal  @db.Decimal(12, 2)
  // internalOnly amounts (cost/margin) are never serialized to CLIENT users.
  internalOnly  Boolean  @default(false)
  createdAt     DateTime @default(now())

  roadmapItem RoadmapItem @relation(fields: [roadmapItemId], references: [id], onDelete: Cascade)

  @@index([roadmapItemId])
}

// Internal cost/effort calculator — never client-facing.
model Estimate {
  id          String   @id @default(cuid())
  projectId   String
  name        String   @default("Estimate")
  notes       String?  @db.Text
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User?              @relation(fields: [createdById], references: [id])
  lineItems EstimateLineItem[]
  proposals Proposal[]

  @@index([projectId])
}

model EstimateLineItem {
  id         String  @id @default(cuid())
  estimateId String
  role       String // e.g. "Solutions Architect"
  description String?
  hours      Decimal @db.Decimal(10, 2)
  costRate   Decimal @db.Decimal(10, 2) // internal cost per hour (INTERNAL ONLY)
  sellRate   Decimal @db.Decimal(10, 2) // client-facing rate per hour
  sortOrder  Int     @default(0)

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@index([estimateId])
}

enum ProposalStatus {
  DRAFT
  SENT
  APPROVED
  DECLINED
}

// Client-facing scope & pricing, generated from an Estimate.
// Stores only sell-side numbers — no costRate/margin ever lands here.
model Proposal {
  id          String         @id @default(cuid())
  projectId   String
  estimateId  String?
  title       String
  status      ProposalStatus @default(DRAFT)
  scope       Json? // structured scope sections rendered in the shareable view
  totalPrice  Decimal?       @db.Decimal(12, 2)
  publicToken String?        @unique // for a read-only shareable link
  createdById String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  estimate  Estimate? @relation(fields: [estimateId], references: [id], onDelete: SetNull)
  createdBy User?     @relation(fields: [createdById], references: [id])

  @@index([projectId])
}

// ===========================================================================
// Audit
// ===========================================================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String // e.g. "client.create"
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
}
