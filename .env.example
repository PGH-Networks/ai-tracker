# Copy this file to .env and fill in your Azure PostgreSQL details.
# Azure connection strings look like:
# postgresql://username:password@your-server.postgres.database.azure.com:5432/your-database?sslmode=require

DATABASE_URL=postgresql://USERNAME:PASSWORD@SERVER.postgres.database.azure.com:5432/DATABASE?sslmode=require

# Port for the local web server (default: 3000)
PORT=3000
